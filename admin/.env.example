# ── GitHub API ────────────────────────────────────────────────
# Create a token at: https://github.com/settings/tokens/new
# Required scopes: repo (Contents: Read & Write)
GITHUB_TOKEN=ghp_your_token_here

REPO_OWNER=sagarchauhan7792-bot
REPO_NAME=index
REPO_BRANCH=master

# ── Admin Password ────────────────────────────────────────────
# Generate a bcrypt hash of your password by running:
#   node -e "const b=require('bcryptjs');b.hash('YourPassword123',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$10$replace_this_with_your_bcrypt_hash

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────
PORT=3000
